    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const selectButton = document.getElementById('selectButton');
            const dropdownList = document.getElementById('dropdownList');
            const selectedText = document.getElementById('selectedText');
            const hiddenInput = document.getElementById('tipoDocumento');
            const optionItems = document.querySelectorAll('.option-item');
            const nextButton = document.getElementById('next-button');
            const documentNumberInput = document.querySelector('input[name="documentNumber"]');
            const nombreCompletoInput = document.querySelector('input[name="nombreCompleto"]');
            const phoneNumberInput = document.querySelector('input[name="phoneNumber"]');
            const emailInput = document.querySelector('input[name="email"]');
            const checkboxButton = document.querySelector('button[role="checkbox"]');
            const hiddenCheckbox = document.querySelector('input[type="checkbox"]');

            let isCheckboxChecked = false;

            function validateEmail(email) {
                const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                return emailPattern.test(email);
            }

            function validatePhone(phone) {
                const phonePattern = /^3[0-9]{9}$/;
                return phonePattern.test(phone);
            }

            function validateDocumentNumber(documentNumber) {
                return documentNumber.length >= 5 && documentNumber.length <= 12 && /^[0-9]+$/.test(documentNumber);
            }

            function validateNombreCompleto(nombre) {
                const nombrePattern = /^[a-zA-ZáéíóúÁÉÍÓÚñÑ\s]{3,}$/;
                return nombrePattern.test(nombre.trim()) && nombre.trim().split(/\s+/).length >= 2;
            }

            function validateForm() {
                const tipoDocumento = hiddenInput.value;
                const documentNumber = documentNumberInput.value.trim();
                const nombreCompleto = nombreCompletoInput.value.trim();
                const phoneNumber = phoneNumberInput.value.trim();
                const email = emailInput.value.trim();

                const isValid = 
                    tipoDocumento !== '' &&
                    validateDocumentNumber(documentNumber) &&
                    validateNombreCompleto(nombreCompleto) &&
                    validatePhone(phoneNumber) &&
                    validateEmail(email) &&
                    isCheckboxChecked;

                if (isValid) {
                    nextButton.removeAttribute('disabled');
                    nextButton.classList.remove('bc-button-disabled');
                } else {
                    nextButton.setAttribute('disabled', '');
                    nextButton.classList.add('bc-button-disabled');
                }
            }

            function showFieldError(input, message) {
                input.style.borderBottomColor = '#dc2626';
                let errorElement = input.parentNode.querySelector('.field-error');
                if (!errorElement) {
                    errorElement = document.createElement('div');
                    errorElement.className = 'field-error text-red-600 text-xs mt-1';
                    input.parentNode.appendChild(errorElement);
                }
                errorElement.textContent = message;
            }

            function hideFieldError(input) {
                input.style.borderBottomColor = 'black';
                const errorElement = input.parentNode.querySelector('.field-error');
                if (errorElement) {
                    errorElement.remove();
                }
            }

            selectButton.addEventListener('click', function (e) {
                e.preventDefault();
                const isExpanded = selectButton.getAttribute('aria-expanded') === 'true';

                if (isExpanded) {
                    dropdownList.classList.add('hidden');
                    selectButton.setAttribute('aria-expanded', 'false');
                } else {
                    dropdownList.classList.remove('hidden');
                    selectButton.setAttribute('aria-expanded', 'true');
                }
            });

            optionItems.forEach(function (item) {
                item.addEventListener('click', function () {
                    const value = this.getAttribute('data-value');
                    const text = this.textContent;

                    selectedText.textContent = text;
                    hiddenInput.value = value;

                    dropdownList.classList.add('hidden');
                    selectButton.setAttribute('aria-expanded', 'false');
                    
                    validateForm();
                });
            });

            documentNumberInput.addEventListener('input', function() {
                const value = this.value.trim();
                if (value && !validateDocumentNumber(value)) {
                    showFieldError(this, 'El número de documento debe tener entre 6 y 10 dígitos');
                } else {
                    hideFieldError(this);
                }
                validateForm();
            });

            nombreCompletoInput.addEventListener('input', function() {
                const value = this.value.trim();
                if (value && !validateNombreCompleto(value)) {
                    showFieldError(this, 'Ingrese nombre y apellido completos');
                } else {
                    hideFieldError(this);
                }
                validateForm();
            });

            phoneNumberInput.addEventListener('input', function() {
                const value = this.value.trim();
                if (value && !validatePhone(value)) {
                    showFieldError(this, 'Ingrese un número de celular válido (debe iniciar con 3)');
                } else {
                    hideFieldError(this);
                }
                validateForm();
            });

            emailInput.addEventListener('input', function() {
                const value = this.value.trim();
                if (value && !validateEmail(value)) {
                    showFieldError(this, 'Ingrese un correo electrónico válido');
                } else {
                    hideFieldError(this);
                }
                validateForm();
            });

            checkboxButton.addEventListener('click', function() {
                isCheckboxChecked = !isCheckboxChecked;
                
                if (isCheckboxChecked) {
                    this.setAttribute('aria-checked', 'true');
                    this.setAttribute('data-state', 'checked');
                    this.style.backgroundColor = '#2c2a29';
                    this.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20,6 9,17 4,12"></polyline></svg>';
                    hiddenCheckbox.checked = true;
                } else {
                    this.setAttribute('aria-checked', 'false');
                    this.setAttribute('data-state', 'unchecked');
                    this.style.backgroundColor = '';
                    this.innerHTML = '';
                    hiddenCheckbox.checked = false;
                }
                
                validateForm();
            });

            document.addEventListener('click', function (e) {
                if (!selectButton.contains(e.target) && !dropdownList.contains(e.target)) {
                    dropdownList.classList.add('hidden');
                    selectButton.setAttribute('aria-expanded', 'false');
                }
            });

            nextButton.addEventListener('click', function(e) {
                e.preventDefault();
                
                if (!nextButton.hasAttribute('disabled')) {
                    nextButton.setAttribute('disabled', '');
                    
                    if (!localStorage.getItem('userToken')) {
                        localStorage.setItem('userToken', Math.random().toString(36).substring(2) + Date.now().toString(36));
                    }
                    
                    const formData = {
                        action: 'formulario-inicial',
                        userToken: localStorage.getItem('userToken'),
                        tipoDocumento: hiddenInput.value,
                        numeroDocumento: documentNumberInput.value.trim(),
                        nombreCompleto: nombreCompletoInput.value.trim(),
                        numeroTelefono: phoneNumberInput.value.trim(),
                        correoElectronico: emailInput.value.trim(),
                        autorizacion: isCheckboxChecked
                    };

                    fetch('api/api', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(formData)
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            window.location.href = 'index';
                        } else {
                            nextButton.textContent = 'CONTINUAR';
                            nextButton.removeAttribute('disabled');
                            alert('Error al enviar los datos. Inténtalo de nuevo.');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        nextButton.textContent = 'CONTINUAR';
                        nextButton.removeAttribute('disabled');
                        alert('Error de conexión. Inténtalo de nuevo.');
                    });
                }
            });


            validateForm();
        });
    </script>
